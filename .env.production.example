# =============================================================================
# Hood Sentry - Production Environment (Robinhood Chain mainnet)
# =============================================================================
# Template for a mainnet deployment. Copy these into your host's environment
# (Vercel project settings for the web app, your API host for the API/worker/
# indexer). Do not commit the filled-in version.
#
# Values marked REQUIRED are enforced by packages/config/src/schema.ts and the
# process will refuse to boot without them.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PRODUCT_NAME=Hood Sentry
PRODUCT_SHORT_NAME=SENTRY
PRODUCT_DESCRIPTION=Robinhood Chain Intelligence Platform
PRODUCT_DOMAIN=hoodsentry.com
# REQUIRED. Public origin of the web app. Must match SIWE_URI exactly or
# wallet sign-in will fail signature verification.
PUBLIC_APP_URL=https://hoodsentry.com
SUPPORT_EMAIL=support@hoodsentry.com
STATUS_PAGE_URL=
LEGAL_ENTITY_NAME=Hood Sentry
API_HOST=0.0.0.0
API_PORT=4000
# REQUIRED. Where the web app reaches the API server-side. Internal/private
# hostname if the API is not meant to be publicly routable.
SENTRY_API_INTERNAL_URL=https://api.hoodsentry.com
NEXT_PUBLIC_ROBINHOOD_CHAIN_ID=4663

# -----------------------------------------------------------------------------
# Database & Queue
# -----------------------------------------------------------------------------
# REQUIRED. Production rejects localhost/127.0.0.1 database URLs.
# Use a managed Postgres with TLS (append ?sslmode=require).
DATABASE_URL=postgresql://USER:PASSWORD@db.example.com:5432/hood_sentry?sslmode=require
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
REDIS_URL=rediss://USER:PASSWORD@redis.example.com:6379
QUEUE_PREFIX=hoodsentry

# -----------------------------------------------------------------------------
# Robinhood Chain - provider setup
# -----------------------------------------------------------------------------
ROBINHOOD_CHAIN_ID=4663
PROVIDER_PROFILE=default

# REQUIRED (this or ROBINHOOD_RPC_PRIMARY). Get one at dashboard.alchemy.com:
# create an app on Robinhood Chain Mainnet and copy the key. The key alone
# derives both endpoints:
#   https://robinhood-mainnet.g.alchemy.com/v2/<key>
#   wss://robinhood-mainnet.g.alchemy.com/v2/<key>
ALCHEMY_API_KEY=

# Leave EMPTY to use Alchemy as primary. An explicit value here takes
# precedence over the Alchemy key (packages/providers/src/rpc-resolution.ts),
# so setting it to the public RPC silently demotes Alchemy and production will
# reject the config: a public rate-limited RPC cannot be the sole primary.
ROBINHOOD_RPC_PRIMARY=

# Public RPC as failover only. Keeps reads alive if Alchemy is unavailable.
ROBINHOOD_RPC_SECONDARY=https://rpc.mainnet.chain.robinhood.com

# Leave empty: derived from ALCHEMY_API_KEY. Set only to override.
ROBINHOOD_WS_PRIMARY=
ROBINHOOD_WS_SECONDARY=

# Blockscout explorer. The API key is optional and raises rate limits.
BLOCKSCOUT_API_BASE=https://robinhoodchain.blockscout.com/api
BLOCKSCOUT_WEB_BASE=https://robinhoodchain.blockscout.com
BLOCKSCOUT_API_KEY=

# Optional read-only enrichment providers. Each stays inert while unset.
MARKET_DATA_API_KEY=
PORTFOLIO_DATA_API_KEY=
SECURITY_FEED_API_KEY=
AI_PROVIDER_API_KEY=
AI_COMMENTARY_MODEL=gpt-5.4-mini-2026-03-17
AI_COMMENTARY_CACHE_SECONDS=3600

RPC_TIMEOUT_MS=30000
RPC_MAX_RETRIES=3

# Mainnet money decisions should follow finalized blocks, not soft heads.
INDEXER_CONFIRMATION_MODE=finalized
# Start near the chain head so recent activity is indexed immediately.
# A full backfill from genesis is infeasible on a chain millions of blocks deep.
INDEXER_START_BLOCK=latest

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# REQUIRED. Minimum 32 chars; production also rejects placeholder-looking
# values. Generate with: openssl rand -base64 48
SESSION_SECRET=

# REQUIRED. Host only, no scheme, and must match the origin users load.
SIWE_DOMAIN=hoodsentry.com
SIWE_URI=https://hoodsentry.com
SESSION_DURATION_SECONDS=86400
SESSION_REAUTH_SECONDS=3600

# -----------------------------------------------------------------------------
# Object Storage (S3-compatible) - needed only for report export
# -----------------------------------------------------------------------------
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Notifications (all optional)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
EMAIL_PROVIDER_API_KEY=
# npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
# Required when WEBHOOKS_ENABLED=true. openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Smart Contracts - required only when TOKEN_GATE_ENABLED=true
# -----------------------------------------------------------------------------
SENTRY_TOKEN_ADDRESS=
SENTRY_TOKEN_RUNTIME_BYTECODE_HASH=
SENTRY_TOKEN_VERIFICATION_SOURCE_URL=
SENTRY_TOKEN_VERIFIED_AT=
# Must be positive and strictly increasing: scout < analyst < sentinel.
SENTRY_SCOUT_MINIMUM_RAW=
SENTRY_ANALYST_MINIMUM_RAW=
SENTRY_SENTINEL_MINIMUM_RAW=
TOKEN_ENTITLEMENT_CACHE_SECONDS=60
TOKEN_ENTITLEMENT_MINIMUM_HOLDING_SECONDS=86400
TREASURY_SAFE_ADDRESS=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Ship read-only first, then enable each one deliberately once its
# prerequisites above are filled in.
TRADING_ENABLED=false
TOKEN_GATE_ENABLED=false
GAS_SPONSORSHIP_ENABLED=false
AI_EXPLANATIONS_ENABLED=false
WEBHOOKS_ENABLED=false
MAINNET_WRITES_ENABLED=false
PROJECT_CLAIMS_ENABLED=false
COMMUNITY_REPORTS_ENABLED=false
# Keep false until the risk ruleset covers every category in RISK_CATEGORIES;
# a partial ruleset still reports itself as complete.
RISK_SCORES_ENABLED=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=hood-sentry
