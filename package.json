{
  "name": "hood-sentry",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:unit": "turbo run test",
    "test:integration": "turbo run test:integration --concurrency=1",
    "test:e2e": "pnpm --filter @hood-sentry/e2e test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check . && ./scripts/check-process-env.sh",
    "lint:fix": "biome check --write .",
    "lint:env": "./scripts/check-process-env.sh",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "pnpm --filter @hood-sentry/db migrate",
    "db:seed": "pnpm --filter @hood-sentry/db seed",
    "db:reset": "pnpm --filter @hood-sentry/db reset",
    "db:studio": "pnpm --filter @hood-sentry/db studio",
    "contracts:test": "pnpm --filter @hood-sentry/contracts forge:test",
    "contracts:coverage": "pnpm --filter @hood-sentry/contracts forge:coverage",
    "env:init": "node packages/providers/scripts/init-env.mjs",
    "release:check": "./infra/release.sh",
    "smoke": "./infra/smoke-test.sh",
    "setup": "pnpm install && pnpm docker:up && pnpm db:migrate"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
      "protobufjs": "^8.4.1"
    }
  }
}
