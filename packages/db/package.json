{
  "name": "@hood-sentry/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --no-file-parallelism",
    "migrate": "node --env-file-if-exists=../../.env --loader ts-node/esm src/migrate.ts",
    "migrate:reset": "node --loader ts-node/esm src/migrate-reset.ts",
    "seed": "echo 'No seeds yet'",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hood-sentry/chain": "workspace:*",
    "@hood-sentry/discovery-engine": "workspace:*",
    "@hood-sentry/market-engine": "workspace:*",
    "@hood-sentry/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "viem": "^2.22.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
