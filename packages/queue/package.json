{
  "name": "@hood-sentry/queue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --no-file-parallelism",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hood-sentry/shared": "workspace:*",
    "bullmq": "^5.81.1",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
