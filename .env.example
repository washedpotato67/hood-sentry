# =============================================================================
# Hood Sentry - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env files to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PRODUCT_NAME=Hood Sentry
PRODUCT_SHORT_NAME=SENTRY
PRODUCT_DESCRIPTION=Robinhood Chain Intelligence Platform
PRODUCT_DOMAIN=hoodsentry.com
PUBLIC_APP_URL=http://localhost:3000
SUPPORT_EMAIL=support@hoodsentry.com
STATUS_PAGE_URL=
LEGAL_ENTITY_NAME=Hood Sentry
API_HOST=0.0.0.0
API_PORT=4000
SENTRY_API_INTERNAL_URL=http://localhost:4000
NEXT_PUBLIC_ROBINHOOD_CHAIN_ID=46630

# -----------------------------------------------------------------------------
# Database & Queue
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hood_sentry
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
REDIS_URL=redis://localhost:6379
QUEUE_PREFIX=hoodsentry

# -----------------------------------------------------------------------------
# Robinhood Chain
# -----------------------------------------------------------------------------
# Chain ID: 4663 (mainnet) or 46630 (testnet)
ROBINHOOD_CHAIN_ID=46630

# Default provider profile. Add an Alchemy key to derive the matching HTTP and WebSocket endpoints.
PROVIDER_PROFILE=default
ALCHEMY_API_KEY=

# Explicit endpoints override key-derived Alchemy endpoints.
ROBINHOOD_RPC_PRIMARY=

# Secondary RPC (optional but recommended for production)
ROBINHOOD_RPC_SECONDARY=

# WebSocket endpoints for real-time data
ROBINHOOD_WS_PRIMARY=
ROBINHOOD_WS_SECONDARY=

# Blockscout explorer
BLOCKSCOUT_API_BASE=https://robinhoodchain.blockscout.com/api
BLOCKSCOUT_WEB_BASE=https://robinhoodchain.blockscout.com
BLOCKSCOUT_API_KEY=

# Optional read-only enrichment providers
MARKET_DATA_API_KEY=
PORTFOLIO_DATA_API_KEY=
SECURITY_FEED_API_KEY=
AI_PROVIDER_API_KEY=
AI_COMMENTARY_MODEL=gpt-5.4-mini-2026-03-17
AI_COMMENTARY_CACHE_SECONDS=3600

# RPC configuration
RPC_TIMEOUT_MS=30000
RPC_MAX_RETRIES=3

# Indexer confirmation mode: "soft" (faster) or "finalized" (safer)
INDEXER_CONFIRMATION_MODE=soft
# Where a fresh live indexer begins: "latest" (near head), a block number, or empty (genesis)
INDEXER_START_BLOCK=latest
# Max concurrent block fetches during catch-up. Keep low on rate-limited RPC tiers
# (avoids HTTP 429s); raise it when the provider has spare compute-unit budget.
INDEXER_MAX_CONCURRENCY=3

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# SIWE (Sign-In with Ethereum) configuration
SIWE_DOMAIN=localhost:3000
SIWE_URI=http://localhost:3000
SESSION_DURATION_SECONDS=86400
SESSION_REAUTH_SECONDS=3600

# -----------------------------------------------------------------------------
# Object Storage (S3-compatible)
# -----------------------------------------------------------------------------
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
# Telegram bot token (optional)
TELEGRAM_BOT_TOKEN=

# Email provider API key (optional)
EMAIL_PROVIDER_API_KEY=

# Web push notifications (optional)
# Generate VAPID keys: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=

# Webhook signing secret (optional, generate with: openssl rand -hex 32)
WEBHOOK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Smart Contracts (optional - leave empty if not deployed yet)
# -----------------------------------------------------------------------------
SENTRY_TOKEN_ADDRESS=
SENTRY_TOKEN_RUNTIME_BYTECODE_HASH=
SENTRY_TOKEN_VERIFICATION_SOURCE_URL=
SENTRY_TOKEN_VERIFIED_AT=
SENTRY_SCOUT_MINIMUM_RAW=
SENTRY_ANALYST_MINIMUM_RAW=
SENTRY_SENTINEL_MINIMUM_RAW=
TOKEN_ENTITLEMENT_CACHE_SECONDS=60
TOKEN_ENTITLEMENT_MINIMUM_HOLDING_SECONDS=86400
TREASURY_SAFE_ADDRESS=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable features (true/false)
TRADING_ENABLED=false
TOKEN_GATE_ENABLED=false
GAS_SPONSORSHIP_ENABLED=false
AI_EXPLANATIONS_ENABLED=false
WEBHOOKS_ENABLED=false
MAINNET_WRITES_ENABLED=false
PROJECT_CLAIMS_ENABLED=false
COMMUNITY_REPORTS_ENABLED=false
# Publishes the aggregate risk score and grade. Keep false until the risk ruleset covers
# every category in RISK_CATEGORIES; a partial ruleset still reports itself as complete.
RISK_SCORES_ENABLED=false

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=hood-sentry
