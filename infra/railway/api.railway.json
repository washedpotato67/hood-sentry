{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/docker/Dockerfile.api",
    "watchPatterns": [
      "infra/railway/**",
      "apps/api/**",
      "packages/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "preDeployCommand": ["node packages/db/dist/migrate.js"],
    "healthcheckPath": "/health/ready",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "overlapSeconds": 30,
    "drainingSeconds": 30
  }
}
