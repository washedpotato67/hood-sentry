{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/docker/Dockerfile.worker",
    "watchPatterns": [
      "apps/worker/**",
      "packages/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "restartPolicyType": "ALWAYS",
    "overlapSeconds": "30",
    "drainingSeconds": "60"
  }
}
