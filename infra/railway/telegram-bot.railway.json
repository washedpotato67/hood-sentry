{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/docker/Dockerfile.telegram-bot",
    "watchPatterns": [
      "apps/telegram-bot/**",
      "packages/config/**",
      "packages/observability/**",
      "packages/shared/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "restartPolicyType": "ALWAYS",
    "overlapSeconds": "0",
    "drainingSeconds": "30"
  }
}
