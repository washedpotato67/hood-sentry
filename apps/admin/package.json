{
  "name": "@hood-sentry/admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "list": "tsx src/cli.ts list",
    "grant": "tsx src/cli.ts grant",
    "revoke": "tsx src/cli.ts revoke",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hood-sentry/config": "workspace:*",
    "@hood-sentry/db": "workspace:*",
    "@hood-sentry/observability": "workspace:*",
    "@hood-sentry/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "viem": "^2.55.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
