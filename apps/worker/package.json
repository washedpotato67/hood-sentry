{
  "name": "@hood-sentry/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --no-file-parallelism",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hood-sentry/alert-engine": "workspace:*",
    "@hood-sentry/auth": "workspace:*",
    "@hood-sentry/chain": "workspace:*",
    "@hood-sentry/config": "workspace:*",
    "@hood-sentry/db": "workspace:*",
    "@hood-sentry/discovery-engine": "workspace:*",
    "@hood-sentry/market-engine": "workspace:*",
    "@hood-sentry/observability": "workspace:*",
    "@hood-sentry/providers": "workspace:*",
    "@hood-sentry/queue": "workspace:*",
    "@hood-sentry/risk-engine": "workspace:*",
    "@hood-sentry/shared": "workspace:*",
    "bullmq": "^5.81.1",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.4.2",
    "viem": "^2.22.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
