{
  "name": "@hood-sentry/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --no-file-parallelism --passWithNoTests src/__tests__/product.integration.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@hood-sentry/api-contracts": "workspace:*",
    "@hood-sentry/auth": "workspace:*",
    "@hood-sentry/chain": "workspace:*",
    "@hood-sentry/config": "workspace:*",
    "@hood-sentry/db": "workspace:*",
    "@hood-sentry/discovery-engine": "workspace:*",
    "@hood-sentry/entitlements": "workspace:*",
    "@hood-sentry/feature-flags": "workspace:*",
    "@hood-sentry/observability": "workspace:*",
    "@hood-sentry/providers": "workspace:*",
    "@hood-sentry/queue": "workspace:*",
    "@hood-sentry/shared": "workspace:*",
    "@hood-sentry/trading": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "viem": "^2.55.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@hood-sentry/market-engine": "workspace:*",
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
