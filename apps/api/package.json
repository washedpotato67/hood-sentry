{
  "name": "@hood-sentry/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hood-sentry/api-contracts": "workspace:*",
    "@hood-sentry/config": "workspace:*",
    "@hood-sentry/db": "workspace:*",
    "@hood-sentry/feature-flags": "workspace:*",
    "@hood-sentry/observability": "workspace:*",
    "@hood-sentry/shared": "workspace:*",
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@hood-sentry/chain": "workspace:*",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
