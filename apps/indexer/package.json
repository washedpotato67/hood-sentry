{
  "name": "@hood-sentry/indexer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file-if-exists=../../.env src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --no-file-parallelism",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@hood-sentry/chain": "workspace:*",
    "@hood-sentry/config": "workspace:*",
    "@hood-sentry/db": "workspace:*",
    "@hood-sentry/observability": "workspace:*",
    "@hood-sentry/providers": "workspace:*",
    "@hood-sentry/queue": "workspace:*",
    "@hood-sentry/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "viem": "^2.22.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
